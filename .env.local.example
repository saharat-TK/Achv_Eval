# =====================================================================
# Environment variables for local development.
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` — it is gitignored.
# =====================================================================

# ----- Supabase ------------------------------------------------------
# Project URL and anon (public) key come from Supabase dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://msyvlbdyynbesfkpdpip.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key bypasses RLS. Used only in server-side actions that
# perform privileged operations (e.g. system seed, scheduled jobs).
# NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string (used by `supabase` CLI for migrations).
# Get from Supabase dashboard → Settings → Database → Connection string.
# Use the connection pooler URL for production deployments.
SUPABASE_DB_URL=

# ----- Google OAuth (Supabase Auth provider) -------------------------
# Configure in Supabase dashboard → Authentication → Providers → Google.
# The values below are for reference only; Supabase manages the actual flow.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Google APIs (Drive, Sheets, Gmail) ----------------------------
# Service account JSON for backend access to the QA Department's shared Drive.
# Store the JSON file outside the repo and reference its path here.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=

# Or, alternatively, paste the JSON contents inline (base64-encoded).
GOOGLE_SERVICE_ACCOUNT_KEY_B64=

# Root Drive folder ID under the QA Department's account where reports live.
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Google Sheet ID for the lecturer-action log mirror.
GOOGLE_LOG_SHEET_ID=

# ----- Gemini --------------------------------------------------------
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# ----- App -----------------------------------------------------------
# Production URL for the auth callback. Use http://localhost:3000 locally.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Domain restriction for sign-in. Comma-separated list.
ALLOWED_EMAIL_DOMAINS=mfu.ac.th
