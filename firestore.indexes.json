      "collectionGroup": "offerings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "programId", "order": "ASCENDING" },
        { "fieldPath": "academicYear", "order": "ASCENDING" },
        { "fieldPath": "semester", "order": "ASCENDING" }
      ]
    },
    {
      "comment": "A lecturer's own offerings, most recently updated first",
      "collectionGroup": "offerings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "lecturerId", "order": "ASCENDING" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    },
    {
      "comment": "Offerings by status within a program (dashboard / tracking)",
      "collectionGroup": "offerings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "programId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "comment": "Assessor inbox: offerings awaiting assessment in a semester",
      "collectionGroup": "offerings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "programId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "academicYear", "order": "ASCENDING" },
        { "fieldPath": "semester", "order": "ASCENDING" }
      ]
    },
    {
      "comment": "Unread notifications for a recipient, newest first",
      "collectionGroup": "notifications",
