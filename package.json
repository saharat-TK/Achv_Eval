{
  "name": "achv-evaluation-app",
  "version": "0.1.0",
  "private": true,
  "description": "Course Evaluation & Monitoring System — School of Health Science, MFU",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "assign-lecturer": "tsx --env-file=.env.local scripts/assign-lecturer.ts",
    "assign-role": "tsx --env-file=.env.local scripts/assign-role.ts",
    "backfill-lecturer-role": "tsx --env-file=.env.local scripts/backfill-lecturer-role.ts",
    "backfill-academic-role-scope": "tsx --env-file=.env.local scripts/backfill-academic-program-role-scope.ts",
    "backfill-external-assessor-viewer": "tsx --env-file=.env.local scripts/backfill-external-assessor-viewer.ts",
    "firebase:rules": "firebase deploy --only firestore:rules",
    "firebase:indexes": "firebase deploy --only firestore:indexes"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@opentelemetry/api": "^1.9.0",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "googleapis": "^144.0.0",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "firebase-tools": "^13.23.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
